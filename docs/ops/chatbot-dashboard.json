{
  "title": "CivicConnect Chatbot",
  "panels": [
    {
      "title": "Requests by Source",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(chatbot_requests_total[5m])) by (source)"
        }
      ]
    },
    {
      "title": "Fallback Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(chatbot_fallback_total[5m])) / clamp_min(sum(rate(chatbot_requests_total[5m])), 1)"
        }
      ]
    },
    {
      "title": "P95 Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(chatbot_request_latency_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "title": "Errors",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(chatbot_errors_total[5m])) by (endpoint)"
        }
      ]
    }
  ]
}
